#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"

if [[ -n "${CODEX_MEMORY_TEMPLATE_ROOT:-}" ]]; then
  TEMPLATE_ROOT="$CODEX_MEMORY_TEMPLATE_ROOT"
elif [[ -d "$SCRIPT_DIR/../templates/AI Memory" ]]; then
  TEMPLATE_ROOT="${SCRIPT_DIR:h}"
elif [[ -d "$HOME/Desktop/ObsidianVault/ai-memory-public/templates/AI Memory" ]]; then
  TEMPLATE_ROOT="$HOME/Desktop/ObsidianVault/ai-memory-public"
else
  TEMPLATE_ROOT=""
fi

TARGET_ROOT="$PWD"
TODAY="$(date +%F)"

usage() {
  cat <<'USAGE'
Usage: codex-project [--lang en|ru] [--cloud-root DIR] [--project-name NAME] [--auto-write-memory] [--init-only] [--no-start] [--help] [-- <codex args...>]

Initializes the current directory with public Obsidian AI Memory templates
when they are missing, then starts Codex with this directory as workspace.

Options:
  --lang en|ru       Choose template language. Default: en.
  --cloud-root DIR   Store AI Memory in DIR/PROJECT/AI Memory and link it into the project.
  --project-name NAME
                     Override the cloud folder name. Default: current directory name.
  --auto-write-memory
                     Allow the agent to update AI Memory without asking for per-write confirmation.
                     This is unsafe and requires an interactive warning confirmation.
  --init-only        Initialize memory files and exit without starting Codex.
  --no-start         Same as --init-only.
  --help             Show this help.

Environment:
  CODEX_MEMORY_TEMPLATE_ROOT  Override template root.
  CODEX_MEMORY_LANG           Default template language: en or ru.
  CODEX_MEMORY_CLOUD_ROOT     Default cloud root for shared project memory.
USAGE
}

init_only=0
lang="${CODEX_MEMORY_LANG:-en}"
cloud_root="${CODEX_MEMORY_CLOUD_ROOT:-}"
project_name="${CODEX_MEMORY_PROJECT_NAME:-${TARGET_ROOT:t}}"
auto_write_memory=0
codex_args=()

while (($#)); do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --init-only|--no-start)
      init_only=1
      shift
      ;;
    --lang)
      if (($# < 2)); then
        print -u2 "codex-project: --lang requires en or ru"
        exit 1
      fi
      lang="$2"
      shift 2
      ;;
    --lang=*)
      lang="${1#--lang=}"
      shift
      ;;
    --cloud-root)
      if (($# < 2)); then
        print -u2 "codex-project: --cloud-root requires a directory"
        exit 1
      fi
      cloud_root="$2"
      shift 2
      ;;
    --cloud-root=*)
      cloud_root="${1#--cloud-root=}"
      shift
      ;;
    --project-name)
      if (($# < 2)); then
        print -u2 "codex-project: --project-name requires a name"
        exit 1
      fi
      project_name="$2"
      shift 2
      ;;
    --project-name=*)
      project_name="${1#--project-name=}"
      shift
      ;;
    --auto-write-memory)
      auto_write_memory=1
      shift
      ;;
    --)
      shift
      codex_args+=("$@")
      break
      ;;
    *)
      codex_args+=("$1")
      shift
      ;;
  esac
done

case "$lang" in
  en|ru) ;;
  *)
    print -u2 "codex-project: unsupported language: $lang"
    print -u2 "Supported languages: en, ru"
    exit 1
    ;;
esac

if [[ -z "$TEMPLATE_ROOT" ]]; then
  print -u2 "codex-project: template root not found."
  print -u2 "Run from a cloned ai-memory-public repo, install via ./install.sh, or set CODEX_MEMORY_TEMPLATE_ROOT."
  exit 1
fi

if [[ "$lang" == "ru" ]]; then
  TEMPLATE_MEMORY="$TEMPLATE_ROOT/locales/ru/templates/AI Memory"
  TEMPLATE_AGENTS="$TEMPLATE_ROOT/locales/ru/AGENTS.md"
else
  TEMPLATE_MEMORY="$TEMPLATE_ROOT/templates/AI Memory"
  TEMPLATE_AGENTS="$TEMPLATE_ROOT/AGENTS.md"
fi

if [[ ! -d "$TEMPLATE_MEMORY" ]]; then
  print -u2 "codex-project: template directory not found: $TEMPLATE_MEMORY"
  exit 1
fi

if [[ ! -f "$TEMPLATE_AGENTS" ]]; then
  print -u2 "codex-project: template AGENTS.md not found: $TEMPLATE_AGENTS"
  exit 1
fi

created=()
skipped=()
warnings=()
cloud_memory=""
mirror_to_cloud=0

confirm_auto_write_memory() {
  local required="ENABLE AUTO MEMORY WRITE"
  local answer=""

  if command -v osascript >/dev/null 2>&1; then
    osascript >/dev/null 2>&1 <<'APPLESCRIPT' || true
display dialog "Auto-write memory mode lets the agent modify AI Memory files without asking before each write. Use it only in trusted projects. Secrets must never be stored." buttons {"Cancel", "Continue"} default button "Cancel" with icon caution
APPLESCRIPT
  fi

  print ""
  print "WARNING: --auto-write-memory enables autonomous writes to AI Memory."
  print "The agent may update memory files without per-write confirmation."
  print "Risks: noisy memory, wrong durable facts, accidental persistence of sensitive context."
  print "Safeguards remain: no secrets, append-only preference, duplicate/conflict checks, log updates, no git commits."
  print ""
  print "Type exactly '$required' to enable it for this project:"

  if ! read -r answer; then
    print -u2 "codex-project: auto-write-memory confirmation failed."
    exit 1
  fi

  if [[ "$answer" != "$required" ]]; then
    print -u2 "codex-project: auto-write-memory was not enabled."
    exit 1
  fi
}

append_auto_write_rules() {
  local agents_file="$1"
  local mode_lang="$2"

  if rg -q '^## Autonomous Memory Write Mode$|^## Автономная запись в память$' "$agents_file" 2>/dev/null; then
    skipped+=("AGENTS.md autonomous memory write rules")
    return
  fi

  if [[ "$mode_lang" == "ru" ]]; then
    cat >> "$agents_file" <<'RULES'

## Автономная запись в память

Этот проект запущен с включённым `--auto-write-memory`.

Агент может обновлять файлы `AI Memory/` без отдельного подтверждения перед каждой записью, если обнаружил устойчивую информацию, полезную для будущих AI coding sessions.

Разрешено автоматически сохранять:

- проверенные команды запуска, тестов, сборки, линтинга и диагностики
- архитектурные решения и связи компонентов
- настройки окружения разработки и setup steps
- conventions проекта и правила именования
- известные проблемы, ограничения, workaround и риски
- устойчивые задачи, roadmap items и follow-ups
- краткие итоги существенных coding sessions

Перед записью всё равно нужно:

1. Прочитать `AI Memory/_index.md`.
2. Выбрать целевой memory-файл.
3. Прочитать целевой файл.
4. Проверить дубли по смыслу.
5. Проверить конфликты с активными фактами.
6. Предпочитать append-only изменения.
7. Добавить запись в `AI Memory/_log.md`.

Нельзя автоматически сохранять секреты, токены, пароли, private keys, credentials, private URLs, лишние персональные данные, догадки, временный вывод терминала, одноразовые ошибки или низкоценный шум.

Если есть конфликт, риск секрета, сомнение в устойчивости факта или запись требует изменения файлов вне `AI Memory/`, нужно сначала спросить пользователя.

Git commit и push всё равно запрещены без явной команды пользователя.
RULES
  else
    cat >> "$agents_file" <<'RULES'

## Autonomous Memory Write Mode

This project was initialized with `--auto-write-memory`.

The agent may update `AI Memory/` files without asking for per-write confirmation when it finds durable information useful for future AI coding sessions.

The agent may automatically save:

- verified run, test, build, lint, and diagnostic commands
- architecture decisions and component relationships
- development environment settings and setup steps
- project conventions and naming rules
- known issues, limitations, workarounds, and risks
- durable tasks, roadmap items, and follow-ups
- concise summaries of substantial coding sessions

Before writing, the agent must still:

1. Read `AI Memory/_index.md`.
2. Choose the target memory file.
3. Read the target file.
4. Check duplicates by meaning.
5. Check conflicts against active facts.
6. Prefer append-only edits.
7. Append a log entry to `AI Memory/_log.md`.

Never automatically save secrets, tokens, passwords, private keys, credentials, private URLs, unnecessary personal data, guesses, transient terminal output, one-off errors, or low-value noise.

If there is a conflict, a possible secret, uncertainty about whether the fact is durable, or a write would modify files outside `AI Memory/`, ask the user first.

Git commit and push are still forbidden unless the user explicitly asks for them.
RULES
  fi

  created+=("AGENTS.md autonomous memory write rules")
}

if [[ -e "$TARGET_ROOT/AGENTS.md" ]]; then
  skipped+=("AGENTS.md")
else
  cp "$TEMPLATE_AGENTS" "$TARGET_ROOT/AGENTS.md"
  created+=("AGENTS.md")
fi

if (( auto_write_memory )); then
  confirm_auto_write_memory
  append_auto_write_rules "$TARGET_ROOT/AGENTS.md" "$lang"
fi

MEMORY_DIR="$TARGET_ROOT/AI Memory"

if [[ -n "$cloud_root" ]]; then
  cloud_root="${cloud_root:A}"
  cloud_memory="$cloud_root/$project_name/AI Memory"
  mkdir -p "$cloud_memory"

  if [[ -L "$MEMORY_DIR" ]]; then
    current_target="$(readlink "$MEMORY_DIR")"
    skipped+=("AI Memory symlink -> $current_target")
  elif [[ -e "$MEMORY_DIR" ]]; then
    warnings+=("AI Memory already exists as a regular file or directory; not replacing it with a cloud symlink.")
    warnings+=("A non-destructive copy will be mirrored to: $cloud_memory")
    warnings+=("For ongoing cross-device sync, move or rename the local AI Memory directory, then rerun codex-project --cloud-root to link it.")
    mirror_to_cloud=1
  else
    ln -s "$cloud_memory" "$MEMORY_DIR"
    created+=("AI Memory -> $cloud_memory")
  fi

  if [[ -L "$MEMORY_DIR" ]]; then
    MEMORY_DIR="$cloud_memory"
  elif [[ ! -e "$MEMORY_DIR" ]]; then
    MEMORY_DIR="$cloud_memory"
  fi
fi

mkdir -p "$MEMORY_DIR"

for src in "$TEMPLATE_MEMORY"/*.md(N); do
  name="${src:t}"
  dest="$MEMORY_DIR/$name"
  if [[ -e "$dest" ]]; then
    skipped+=("AI Memory/$name")
    continue
  fi

  cp "$src" "$dest"
  perl -pi -e "s/YYYY-MM-DD/$TODAY/g" "$dest"
  created+=("AI Memory/$name")
done

if (( mirror_to_cloud )); then
  rsync -a --ignore-existing "$MEMORY_DIR/" "$cloud_memory/"
  created+=("cloud mirror -> $cloud_memory")
fi

if (( ${#created[@]} )); then
  print "codex-project: created:"
  for item in "${created[@]}"; do
    print "  + $item"
  done
else
  print "codex-project: memory structure already exists."
fi

if (( ${#skipped[@]} )); then
  print "codex-project: skipped existing files:"
  for item in "${skipped[@]}"; do
    print "  = $item"
  done
fi

if (( ${#warnings[@]} )); then
  print "codex-project: warnings:"
  for item in "${warnings[@]}"; do
    print "  ! $item"
  done
fi

if (( init_only )); then
  exit 0
fi

exec codex -C "$TARGET_ROOT" "${codex_args[@]}"
